#!/bin/sh
# Versioneret pre-commit hook (aktiveres med: git config core.hooksPath .githooks)
# Blokerer commit af Excel-filer med persondata (navn/CPR/mail).
dir="$(dirname "$0")"
if command -v python >/dev/null 2>&1; then PY=python
elif command -v py >/dev/null 2>&1; then PY=py
else echo "pre-commit: python ikke fundet - kan ikke scanne Excel for persondata" >&2; exit 1
fi
exec "$PY" "$dir/check_excel_pii.py"
